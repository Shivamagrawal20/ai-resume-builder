NODE_ENV=development
PORT=4000
# Production: comma-separated frontend origins that may call this API with cookies / Authorization
# CORS_ORIGIN=https://your-app.netlify.app,https://www.yoursite.com
# Behind Railway/Render/Fly/nginx: TRUST_PROXY=1
# TRUST_PROXY=1
MONGODB_URI=mongodb://127.0.0.1:27017/ai-resume-builder
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Google AI Studio / Gemini API — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash; gemini-1.5-* is retired — use AI Studio “Get code” model names)
# GEMINI_MODEL=gemini-2.5-flash-lite
